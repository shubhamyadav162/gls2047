# Server Configuration
PORT=5000
NODE_ENV=production
API_BASE_URL=https://api.gls2026.org
FRONTEND_URL=https://gls2026.org

# Database
MONGODB_URI=mongodb://localhost:27017/gls2026
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/gls2026

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Email Configuration (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=GLS 2026 <noreply@gls2026.org>

# Alternative: SendGrid
# SENDGRID_API_KEY=your_sendgrid_api_key

# PayU Payment Gateway
PAYU_MERCHANT_KEY=your_payu_merchant_key
PAYU_MERCHANT_SALT=your_payu_merchant_salt
PAYU_SUCCESS_URL=https://gls2026.org/payment-success
PAYU_FAILURE_URL=https://gls2026.org/payment-failure
PAYU_BASE_URL=https://secure.payu.in/_payment
# For Testing: https://test.payu.in/_payment

# Easebuzz Payment Gateway
EASEBUZZ_MERCHANT_KEY=your_easebuzz_merchant_key
EASEBUZZ_SALT=your_easebuzz_salt
EASEBUZZ_SUCCESS_URL=https://gls2026.org/payment-success
EASEBUZZ_FAILURE_URL=https://gls2026.org/payment-failure
EASEBUZZ_BASE_URL=https://pay.easebuzz.in/pay
# For Testing: https://testpay.easebuzz.in/pay

# Admin Credentials (Change these!)
ADMIN_EMAIL=admin@gls2026.org
ADMIN_PASSWORD=ChangeThisStrongPassword123!

# Security
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=1800000

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Razorpay (Optional alternative)
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# SMS Gateway (Optional - for OTP)
# SMS_API_KEY=your_sms_api_key
# SMS_SENDER_ID=GLSMIT
